PORT=3000

# Base de datos MySQL (local o Aiven en producción)
DB_HOST=
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_PORT=3306
# En Aiven (y la mayoría de los MySQL gestionados) hace falta SSL: poner "true"
DB_SSL=false

JWT_SECRET=

# Backblaze B2 (opcional): si se completan estas 3 variables, los archivos
# subidos (videos, imágenes de dibujo táctico, PDFs de cargas físicas) se
# guardan en B2 en vez de en el disco del servidor. Necesario en hosts sin
# disco persistente (como Render). Si se dejan vacías, se usa disco local.
B2_KEY_ID=
B2_APP_KEY=
B2_BUCKET=
B2_ENDPOINT=
B2_REGION=auto
